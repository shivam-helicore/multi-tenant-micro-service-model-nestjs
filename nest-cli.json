{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true
  },
  "monorepo": true,
  "root": "apps/prts-platform",
  "projects": {
    "activity": {
      "type": "library",
      "root": "libs/activity",
      "entryFile": "index",
      "sourceRoot": "libs/activity/src",
      "compilerOptions": {
        "tsConfigPath": "libs/activity/tsconfig.lib.json"
      }
    },
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "application-service": {
      "type": "application",
      "root": "apps/application-service",
      "entryFile": "main",
      "sourceRoot": "apps/application-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/application-service/tsconfig.app.json"
      }
    },
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    },
    "logger": {
      "type": "library",
      "root": "libs/logger",
      "entryFile": "index",
      "sourceRoot": "libs/logger/src",
      "compilerOptions": {
        "tsConfigPath": "libs/logger/tsconfig.lib.json"
      }
    },
    "metrics": {
      "type": "library",
      "root": "libs/metrics",
      "entryFile": "index",
      "sourceRoot": "libs/metrics/src",
      "compilerOptions": {
        "tsConfigPath": "libs/metrics/tsconfig.lib.json"
      }
    },
    "nest": {
      "type": "library",
      "root": "libs/generate/nest",
      "entryFile": "index",
      "sourceRoot": "libs/generate/nest/src",
      "compilerOptions": {
        "tsConfigPath": "libs/generate/nest/tsconfig.lib.json"
      }
    },
    "notification-service": {
      "type": "application",
      "root": "apps/notification-service",
      "entryFile": "main",
      "sourceRoot": "apps/notification-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notification-service/tsconfig.app.json"
      }
    },
    "notifications": {
      "type": "library",
      "root": "libs/notifications",
      "entryFile": "index",
      "sourceRoot": "libs/notifications/src",
      "compilerOptions": {
        "tsConfigPath": "libs/notifications/tsconfig.lib.json"
      }
    },
    "prts-platform": {
      "type": "application",
      "root": "apps/prts-platform",
      "entryFile": "main",
      "sourceRoot": "apps/prts-platform/src",
      "compilerOptions": {
        "tsConfigPath": "apps/prts-platform/tsconfig.app.json"
      }
    },
    "rbac": {
      "type": "library",
      "root": "libs/rbac",
      "entryFile": "index",
      "sourceRoot": "libs/rbac/src",
