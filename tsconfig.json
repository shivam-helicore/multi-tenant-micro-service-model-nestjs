{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": false,
    "paths": {
      "@prts/activity": [
        "libs/activity/src"
      ],
      "@prts/activity/*": [
        "libs/activity/src/*"
      ],
      "@prts/common/*": [
        "libs/common/src/*"
      ],
      "@prts/tenant": [
        "libs/tenant/src"
      ],
      "@prts/tenant/*": [
        "libs/tenant/src/*"
      ],
      "@prts/cache/redis": [
        "libs/cache/redis/src"
      ],
      "@prts/cache/redis/*": [
        "libs/cache/redis/src/*"
      ],
      "@prts/messaging/rabbitmq": [
        "libs/messaging/rabbitmq/src"
      ],
      "@prts/messaging/rabbitmq/*": [
        "libs/messaging/rabbitmq/src/*"
      ],
      "@prts/core/config": [
        "libs/core/config/src"
      ],
      "@prts/core/config/*": [
        "libs/core/config/src/*"
      ],
      "@prts/dto": [
        "libs/dto/src"
      ],
      "@prts/dto/*": [
        "libs/dto/src/*"
      ],
      "@prts/auth": [
        "libs/auth/src"
      ],
      "@prts/auth/*": [
        "libs/auth/src/*"
      ],
      "@prts/audit": [
        "libs/audit/src"
      ],
      "@prts/audit/*": [
        "libs/audit/src/*"
      ],
      "@prts/rbac": [
        "libs/rbac/src"
      ],
      "@prts/rbac/*": [
        "libs/rbac/src/*"
      ],
      "@prts/database": [
        "libs/database/src"
      ],
      "@prts/database/*": [
        "libs/database/src/*"
      ],
      "@prts/logger": [
        "libs/logger/src"
      ],
      "@prts/logger/*": [
        "libs/logger/src/*"
      ],
      "@prts/metrics": [
        "libs/metrics/src"
      ],
      "@prts/metrics/*": [
        "libs/metrics/src/*"
      ]
    }
  }
}